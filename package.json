{
  "name": "devmentor-ai",
  "displayName": "devmentor-ai",
  "description": "AI powered developer mentor for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
"contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devmentor-container",
          "title": "DevMentor AI",
          "icon": "$(robot)"
        }
      ]
    },
    "views": {
      "devmentor-container": [
        {
          "type": "webview",
          "id": "devmentor-sidebar",
          "name": "DevMentor AI"
        }
      ]
    },
    "commands": [
      {
        "command": "devmentor-ai.analyze",
        "title": "DevMentor: Analyze My Code"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "node-fetch": "^3.3.2"
  }
}
